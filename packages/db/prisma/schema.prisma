generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id        String      @id @default(uuid()) 
  email     String      @unique
  image     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  projects  Project[]
}

model Project {
  id        String    @id @default(uuid())
  title     String?
  sandboxId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId],references: [id])
  history   History[]
}

enum HistoryType {
  TOOL_CALL
  TEXT_MESSAGE
}

enum Role {
  USER
  ASSISTANT
}

enum ToolCall {
  BASH_TOOL
  QNA_TOOL
}

model History {
  id        String       @id @default(uuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  type      HistoryType
  from      Role
  contents  String
  toolCall  ToolCall?
  createdAt DateTime     @default(now())
}